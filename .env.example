# ─── Anthropic — Claude Sonnet 4.6 scoring ───
ANTHROPIC_API_KEY=

# ─── Hume AI — EVI 2 voice agent + Expression Measurement ───
HUME_API_KEY=
HUME_SECRET_KEY=
HUME_EVI_CONFIG_ID=

# ─── Zoho Creator — POST scored sessions, read AI_Config (Phase 1A) ───
ZOHO_REGION=us
ZOHO_CREATOR_OWNER=centrocdx
ZOHO_CREATOR_APP=centro-ai-recruiter
ZOHO_CREATOR_OAUTH_CLIENT_ID=
ZOHO_CREATOR_OAUTH_CLIENT_SECRET=
ZOHO_CREATOR_OAUTH_REFRESH_TOKEN=

# ─── Zoho WorkDrive — upload session recordings (Phase 1B) ───
# Folder where AI Recruiter recordings land. Get the folder ID from the WorkDrive URL
# when you have the destination folder open: https://workdrive.zoho.com/folder/<ID>
ZOHO_WORKDRIVE_FOLDER_ID=

# ─── AWS Rekognition + Textract — ID verification (Phase 1C) ───
# Rekognition isn't available in me-south-1; eu-central-1 is the closest supported.
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Confidence threshold above which the face match is considered verified (0-100, default 85)
AWS_REKOGNITION_MATCH_THRESHOLD=85

# ─── Admin dashboard auth — Phase 1D (HTTP Basic Auth until Zoho SSO ships) ───
ADMIN_USERNAME=
ADMIN_PASSWORD=
